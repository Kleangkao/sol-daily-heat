# Solana Daily Heat Scanner — all keys optional for UI (mock fallback)

# Supabase (required for live ingest + rankings)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron protection — REQUIRED in production (NODE_ENV=production returns 401 if unset)
# Dev (npm run dev) allows cron without secret when this is unset
# Vercel: set in Project → Settings → Environment Variables (not NEXT_PUBLIC_)
# CRON_SECRET=your-random-secret

# Optional AI summaries (disabled when unset)
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Market Pulse — optional; Jupiter works keyless without this
# JUPITER_API_KEY=

# Paid adapters — disabled unless set (stubs only in codebase)
# BIRDEYE_API_KEY=
# HELIUS_API_KEY=
# COINGECKO_API_KEY=
